# URL base da API (Backend)
# Prefixo relativo: o Vite dev server (npm run dev) faz proxy de /api/* para os
# serviços locais, e em produção o Nginx gateway roteia /api/* para cada serviço.
# Não use uma URL absoluta como http://localhost aqui: ela ignora o proxy do Vite.
VITE_API_URL=/api

# Ambiente de execução atual
VITE_ENV_NAME=development

# Local auth bypass for testing protected routes
# Use only during development
VITE_AUTH_BYPASS=false
VITE_AUTH_BYPASS_ROLE=teacher

# Modo debug do front. Quando "true", exibe recursos de debug (ex.: o switch de
# "Modo professor" no menu do perfil, que alterna o papel do usuário logado).
# O endpoint correspondente no auth-service só existe com DJANGO_DEBUG=True.
VITE_DEBUG=false
